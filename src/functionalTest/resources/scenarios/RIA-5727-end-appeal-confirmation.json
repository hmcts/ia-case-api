{
  "description": "RIA-5727 end appeal automatically confirmation",
  "request": {
    "uri": "/asylum/ccdSubmitted",
    "credentials": "SystemUser",
    "input": {
      "eventId": "endAppealAutomatically",
      "state": "submitAppeal",
      "caseData": {
        "template": "minimal-appeal-submitted.json"
      }
    }
